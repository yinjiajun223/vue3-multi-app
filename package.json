{
  "name": "vue3-multi-app",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Vue 3 + Vite multi-entry app template (web + admin)",
  "author": "yinjiajun223",
  "license": "ISC",
  "keywords": [
    "vue3",
    "vite",
    "multi-entry"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "npm run lint:fix",
    "format:check": "npm run lint",
    "prepare": "husky"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "element-plus": "^2.13.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/node": "^25.3.5",
    "@vitejs/plugin-vue": "^6.0.4",
    "eslint": "^9.39.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.5"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,vue,json,md,html,css,scss,yml,yaml}": [
      "eslint --fix"
    ]
  }
}
